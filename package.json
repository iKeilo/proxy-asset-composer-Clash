{
  "name": "proxy-asset-composer",
  "version": "0.0.3",
  "description": "ProxyAssetComposer",
  "main": "electron/main.js",
  "author": "iKeilo",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist:x64": "electron-builder --win portable --x64",
    "dist:ia32": "electron-builder --win portable --ia32",
    "dist:all": "electron-builder --win portable --x64 --ia32"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.codex.proxyassetcomposer",
    "productName": "ProxyAssetComposer",
    "copyright": "iKeilo",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "app/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": true,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ]
    }
  }
}
